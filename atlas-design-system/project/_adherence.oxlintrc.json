{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/collection/**",
              "components/core/**",
              "components/progress/**",
              "marketing/**",
              "ui_kits/mobile/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Hanken Grotesk|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Hanken Grotesk, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AchievementBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|tier|points|unlocked|icon|progress|key|ref|className|style|children)$/]",
        "message": "<AchievementBadge> doesn't accept that prop. Declared props: title, description, tier, points, unlocked, icon, progress."
      },
      {
        "selector": "JSXOpeningElement[name.name='AchievementBadge'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:bronze|silver|gold|platinum)$/]",
        "message": "<AchievementBadge> tier must be one of 'bronze' | 'silver' | 'gold' | 'platinum'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|level|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, level, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|gold|success|info|danger|bronze|silver|platinum|solid)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'gold' | 'success' | 'info' | 'danger' | 'bronze' | 'silver' | 'platinum' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|leftIcon|rightIcon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, leftIcon, rightIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:pad|interactive|emphasis|as|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: pad, interactive, emphasis, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CollectibleItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|meta|icon|image|collected|checkIcon|key|ref|className|style|children)$/]",
        "message": "<CollectibleItem> doesn't accept that prop. Declared props: name, meta, icon, image, collected, checkIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='CollectionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|type|value|max|icon|image|key|ref|className|style|children)$/]",
        "message": "<CollectionCard> doesn't accept that prop. Declared props: title, type, value, max, icon, image."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeatGrid'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|columns|rows|cell|gap|radius|key|ref|className|style|children)$/]",
        "message": "<HeatGrid> doesn't accept that prop. Declared props: data, columns, rows, cell, gap, radius."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|size|color|showValue|valueFormat|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, label, size, color, showValue, valueFormat."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<ProgressBar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:gold|sky|spruce)$/]",
        "message": "<ProgressBar> color must be one of 'gold' | 'sky' | 'spruce'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|stroke|color|label|showValue|children|key|ref|className|style|children)$/]",
        "message": "<ProgressRing> doesn't accept that prop. Declared props: value, max, size, stroke, color, label, showValue, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRing'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:gold|sky|spruce)$/]",
        "message": "<ProgressRing> color must be one of 'gold' | 'sky' | 'spruce'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|level|levelProgress|toNext|key|ref|className|style|children)$/]",
        "message": "<ScoreMeter> doesn't accept that prop. Declared props: score, level, levelProgress, toNext."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|sub|icon|gold|align|size|key|ref|className|style|children)$/]",
        "message": "<StatBlock> doesn't accept that prop. Declared props: value, label, sub, icon, gold, align, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatBlock> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StatBlock> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|count|icon|onRemove|interactive|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: selected, count, icon, onRemove, interactive."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
